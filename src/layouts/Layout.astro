---
import "@fontsource-variable/onest";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { ViewTransitions } from "astro:transitions";

interface Props {
  title: string;
  description: string;
}

const { description, title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="darkreader-lock" />
    <ViewTransitions />
  </head>

  <body class="relative text-black dark:text-white">
    <div
      class="fixed inset-0 z-[-2] bg-gray-50 dark:bg-gray-950
      bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(251,191,36,0.14),rgba(255,255,255,0.9))]
      dark:bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(251,191,36,0.08),rgba(0,0,0,0))]"
    >
    </div>
    <!-- Grain texture overlay for tactile depth -->
    <div
      class="pointer-events-none fixed inset-0 z-[-1] opacity-[0.035] dark:opacity-[0.05]"
      style="background-image: url('/noise.svg'); background-size: 200px 200px;"
      aria-hidden="true"
    >
    </div>
    <Header />
    <slot />
    <Footer />
    <style is:global>
      :root {
        color-scheme: light dark;
      }

      html {
        font-family: "Onest Variable", system-ui, sans-serif;
        scroll-behavior: smooth;
      }

      body {
        color: rgba(17, 17, 17, 0.9);
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        overscroll-behavior: none;
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
      }

      @media (prefers-color-scheme: dark) {
        body {
          color: rgba(255, 255, 255, 0.9);
        }
      }

      @keyframes blur {
        to {
          backdrop-filter: blur(20px);
          border-width: 1px;
          border-color: rgba(0, 0, 0);
          padding: 0.25rem 0.75rem;
          display: flex;
          flex-direction: row;
          align-items: center;
          background-color: rgb(229, 229, 229);
          border-radius: 9999px;
        }
      }

      @media (prefers-color-scheme: dark) {
        @keyframes blur {
          from {
            border: 0px;
          }
          to {
            box-shadow:
              0px 5px 50px -5px rgba(0, 0, 0, 0.1),
              0px 0px 0 1px rgba(0, 0, 0, 0.3);
            background: rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(20px);
            border-width: 1px;
            border-color: rgba(0, 0, 0);
            padding-left: 0.75rem;
            padding-right: 0.75rem;
            padding-top: 0.25rem;
            padding-bottom: 0.25rem;
            display: flex;
            flex-direction: row;
            align-items: center;
            background-color: rgba(0, 0, 0, 0.3);
            border-radius: 9999px;
          }
        }
      }

      /* ── Design system: staggered entrance animations ─────────────── */
      @keyframes fade-in-up {
        from {
          opacity: 0;
          translate: 0 20px;
        }
        to {
          opacity: 1;
          translate: 0 0;
        }
      }

      .anim-fade-in {
        animation: fade-in-up 0.65s cubic-bezier(0.22, 1, 0.36, 1) both;
      }
      .anim-delay-1 { animation-delay: 120ms; }
      .anim-delay-2 { animation-delay: 260ms; }
      .anim-delay-3 { animation-delay: 400ms; }
      .anim-delay-4 { animation-delay: 540ms; }

      /* Gradient text utility for the hero name */
      .gradient-name {
        background: linear-gradient(135deg, #f59e0b 10%, #f97316 90%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        color: transparent;
      }

      /* Scroll-triggered reveal for named sections (below the fold) */
      @supports (animation-timeline: view()) {
        [data-section] {
          animation: fade-in-up 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
          animation-timeline: view();
          animation-range: entry 0% entry 18%;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .anim-fade-in,
        [data-section] {
          animation: none !important;
          opacity: 1 !important;
          translate: none !important;
        }
      }
    </style>
  </body>
</html>
