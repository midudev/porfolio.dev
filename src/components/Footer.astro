---
import HeartFilled from "./icons/HeartFilled.astro"
const currentYear = new Date().getFullYear()
---

<footer
  class="opacity-80 m-4 mt-16 w-full mx-auto container lg:max-w-4xl md:max-w-2xl mb-10 flex justify-center"
>
  <div
    class="rounded-lg w-full max-w-screen-xl mx-auto md:flex md:items-center md:justify-between py-4 flex flex-col md:flex-row items-center gap-4"
  >
    <span class="text-sm text-center text-pretty md:text-left text-zinc-800/90 dark:text-zinc-200/90"
      >&copy; {currentYear}
      <a href="https://midu.dev/" class="hover:underline">midudev</a>. Hecho con <HeartFilled class="size-3.5 text-red-500 inline" aria-label="amor" /> Casi
      todos los derechos reservados
    </span>
    <ul
      class="flex flex-wrap items-center text-sm font-medium dark:text-white/90"
    >
      <li>
        <a id="contacto" href="mailto:miduga@gmail.com" class="hover:underline"
          >Contacto</a
        >
      </li>
    </ul>
  </div>
</footer>
