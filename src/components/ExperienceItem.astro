---
import LinkInline from "./LinkInline.astro";
import ArrowRight from "./icons/ArrowRight.astro";

interface Props {
  title: string;
  company: string;
  description: string;
  link?: string;
  date: string;
  current?: boolean;
}

const {
  title,
  company,
  description,
  link,
  date,
  current = false,
} = Astro.props;
---

<div class="experience-item">
  <div class="experience-side">
    <span
      class={`experience-dot ${current ? "is-current" : ""}`}
      aria-hidden="true"></span>
    <h3 class="experience-role">{title}</h3>
    <h4 class="experience-company">{company}</h4>
    <time class="experience-date">{date}</time>
  </div>
  <div>
    <p class="experience-description">{description}</p>
    {
      link && (
        <LinkInline href={link}>
          Saber más sobre {company} <ArrowRight aria-hidden="true" />
        </LinkInline>
      )
    }
  </div>
</div>
