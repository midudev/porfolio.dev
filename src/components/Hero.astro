---
const personalImageAlt = "Miguel Ángel";
import Badge from "@/components/Badge.astro";
import GitLabIcon from "@/components/icons/GitLab.astro";
import LinkedInIcon from "@/components/icons/LinkedIn.astro";
import SparklesIcon from "@/components/icons/Sparkles.astro";
import SocialPill from "@/components/SocialPill.astro";
---

<div class="hero">
  <div class="hero-top anim-fade-in">
    <div class="hero-avatar-wrap">
      <div class="hero-avatar-glow" aria-hidden="true"></div>
      <img class="hero-avatar" src="/me.webp" alt={personalImageAlt} />
    </div>
    <a
      href="https://linkedin.com/in/alinedmooner"
      target="_blank"
      rel="noopener noreferrer"
      class="hero-badge-link"
    >
      <Badge><SparklesIcon /> Disponible para trabajar</Badge>
    </a>
  </div>

  <h1 class="hero-title">
    <span id="greeting">Hola</span>, soy <span class="hero-name">Daniel</span>
  </h1>

  <p class="hero-copy anim-fade-in anim-delay-2">
    <strong>Desarrollador de software</strong> con más de 5 años de experiencia en
    <strong>desarrollo web full stack</strong>, ubicado en Bogotá, Colombia 🇨🇴.
    Docente particular y entusiasta de la accesibilidad en todo tipo de
    interfaces y dispositivos.
  </p>

  <nav
    class="hero-social anim-fade-in anim-delay-3"
    aria-label="Redes sociales y contacto"
  >
    <SocialPill href="https://linkedin.com/in/alinedmooner">
      <LinkedInIcon />
      LinkedIn
    </SocialPill>
    <SocialPill href="https://gitlab.com/alinedmooner">
      <GitLabIcon />
      GitLab
    </SocialPill>
  </nav>
</div>

<script>
  const setGreeting = () => {
    const hour = new Date().getHours();
    let greeting = "Hola";

    if (hour >= 5 && hour < 12) {
      greeting = "Hola, buenos días";
    } else if (hour >= 12 && hour < 18) {
      greeting = "Hola, buenas tardes";
    } else if (hour >= 18 && hour < 24) {
      greeting = "Hola, buenas noches";
    } else {
      // Desde las 0:00 hasta las 4:59
      greeting = "¿De madrugada por aquí? Hola";
    }

    const greetingElement = document.getElementById("greeting");
    if (greetingElement) {
      greetingElement.textContent = greeting;
    }
  };

  setGreeting();
  document.addEventListener("astro:page-load", setGreeting);
</script>
